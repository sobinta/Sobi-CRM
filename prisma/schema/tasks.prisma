// ============================================================
// Task Engine — tasks, subtasks, dependencies, comments,
// recurrence, and overdue detection.
// ============================================================

model Task {
  id          String    @id @default(cuid())
  tenantId    String
  title       String
  description String?
  /// todo | in_progress | blocked | done | cancelled
  status      String    @default("todo")
  /// low | normal | high | urgent
  priority    String    @default("normal")
  dueAt       DateTime?
  completedAt DateTime?
  /// Parent task for subtasks.
  parentId    String?
  /// This task is blocked until dependsOnId completes.
  dependsOnId String?
  assigneeId  String? // membership id
  /// Optional link to a business record.
  entityType  String?
  entityId    String?
  /// RRULE-like recurrence string, null = one-off.
  recurrence  String?
  ownerId     String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent   Task?         @relation("Subtasks", fields: [parentId], references: [id])
  subtasks Task[]        @relation("Subtasks")
  comments TaskComment[]

  @@index([tenantId, status])
  @@index([tenantId, assigneeId])
  @@index([tenantId, dueAt])
  @@index([tenantId, entityType, entityId])
}

model TaskComment {
  id        String   @id @default(cuid())
  tenantId  String
  taskId    String
  body      String
  authorId  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId, taskId])
}
