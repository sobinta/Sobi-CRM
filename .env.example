# --- Database ---
# DATABASE_URL: least-privilege tenant runtime (pooler is allowed).
DATABASE_URL="postgresql://sobi_tenant_runtime:sobi_tenant_dev@localhost:5433/coreline?schema=public"
# Better Auth/session resolution. Must not have CRM table grants.
IDENTITY_DATABASE_URL="postgresql://sobi_identity_runtime:sobi_identity_dev@localhost:5433/coreline?schema=public"
# Provisioning, public tenant gateways, and cross-tenant job dispatch only.
SYSTEM_DATABASE_URL="postgresql://sobi_system_runtime:sobi_system_dev@localhost:5433/coreline?schema=public"
# DIRECT_URL: used only by `prisma migrate` — must be a *non-pooled* direct
# connection owned by the migration role (e.g. Supabase's port 5432).
DIRECT_URL="postgresql://coreline:coreline_dev@localhost:5433/coreline?schema=public"
# strict (recommended/production) | warn (local transition) | off (tests only)
TENANT_DB_SECURITY_CHECK="warn"

# --- Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"
JOB_RUNNER_SECRET="local-job-runner-secret-change-in-prod"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Provider-neutral billing state. `manual` means invoices are reconciled by an
# operator; it does not imply an automated payment integration.
BILLING_PROVIDER="manual"

# --- Email (Mailpit in dev: docker compose up) ---
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="SOBI CRM <no-reply@sobicrm.local>"

# --- File storage ---
FILE_STORAGE_DRIVER="local"          # local | s3
FILE_STORAGE_LOCAL_PATH="./storage"
FILE_STORAGE_S3_BUCKET="sobi-files"
FILE_STORAGE_S3_REGION="eu-central-1"
# Omit for AWS S3. MinIO local: http://localhost:9000
FILE_STORAGE_S3_ENDPOINT=""
FILE_STORAGE_S3_FORCE_PATH_STYLE="false"
# Optional on AWS when the workload has an IAM role; required for MinIO.
FILE_STORAGE_S3_ACCESS_KEY_ID=""
FILE_STORAGE_S3_SECRET_ACCESS_KEY=""
FILE_UPLOAD_MAX_BYTES="10485760"
CONTRACT_TOKEN_TTL_DAYS="30"
FILE_SIGNING_SECRET="change-me-too"
# Local development only. Never enable in production.
WEBHOOK_ALLOW_PRIVATE_NETWORKS="false"

# --- Distributed rate limiting ---
# Production requires redis and a redis:// or rediss:// URL.
RATE_LIMIT_BACKEND="memory"           # memory | redis
RATE_LIMIT_REDIS_URL="redis://localhost:6379"
RATE_LIMIT_REDIS_CONNECT_TIMEOUT_MS="1500"

# Job lease must exceed normal job duration; crashed workers are recovered.
JOB_LEASE_MS="300000"

# --- Field encryption (AES-256-GCM, 32 bytes base64) ---
# Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=""

# --- AI providers (all optional; AI features disable gracefully) ---
AI_DEFAULT_PROVIDER=""               # openai | gemini | openrouter | local
OPENAI_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
AI_LOCAL_ENDPOINT=""                 # e.g. http://localhost:11434/v1
